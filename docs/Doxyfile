PROJECT_NAME           = "Rohr Engine"
PROJECT_BRIEF          = "A lightweight C and SDL3 game engine"
OUTPUT_DIRECTORY       = build/docs

INPUT                  = README.md include src/engine_internal.h docs
USE_MDFILE_AS_MAINPAGE = docs/README.md
FILE_PATTERNS          = *.h *.md
RECURSIVE              = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
SKIP_FUNCTION_MACROS   = YES

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

STRIP_FROM_PATH        = .
FULL_PATH_NAMES        = YES

GENERATE_TREEVIEW      = YES
SEARCHENGINE           = YES
